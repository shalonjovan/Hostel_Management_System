	share_settings
	{
			"Room Allocation Officer"
			{
				name = "Room Allocation Officer"
				type = Users_Permissions
				permissions = {Chat:false, Predefined:false, ApiAccess:true, PIIAccess:true, ePHIAccess:true}
				description = "Assign rooms to students based on availability and preferences \n"
				ModulePermissions
				{
					complaints
					{
						enabled= Viewall 
						allFieldsVisible= true 
						ReportPermissions
						{
							complaints_Report={"View"}
							complaints_by_complaint_type={"View"}
						}
					}
					students
					{
						enabled= Viewall 
						allFieldsVisible= true 
						ReportPermissions
						{
							students_Report={"View"}
							students_by_course_department={"View"}
						}
					}
					rooms
					{
						enabled= Create,Viewall,Modifyall,Import,Export,Tab 
						allFieldsVisible= true 
						ReportPermissions
						{
							rooms_Report={"View","Edit","Delete"}
							rooms_by_room_type={"View","Edit","Delete"}
						}
					}
				}
			}
			"Read"
			{
				name = "Read"
				type = Users_Permissions
				permissions = {Chat:true, Predefined:true, ApiAccess:true, PIIAccess:true, ePHIAccess:true}
				description = "This profile will have read permission for all components\n"
			}
			"Write"
			{
				name = "Write"
				type = Users_Permissions
				permissions = {Chat:true, Predefined:true, ApiAccess:true, PIIAccess:true, ePHIAccess:true}
				description = "This profile will have write permission for all components\n"
			}
			"Administrator"
			{
