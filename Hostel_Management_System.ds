 application "Hostel Management System"
 {
 	date format = "dd-MMM-yyyy"
 	time zone = "America/Los_Angeles"
 	time format = "24-hr"
 	forms
	{
		form complaints
		{
			displayname = "Complaints"
			success message = "Complaint Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			student
			(
				type = list	
				displayname = "Student"
				values  = students.ID
    			displayformat = [student_id]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
				height = 13px
	 			row = 1
	 			column = 1   
				width = medium
			)
			room
			(
				type = list	
				displayname = "Room"
				values  = rooms.ID
    			displayformat = [room_id]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
				height = 13px
	 			row = 1
	 			column = 1   
				width = medium
			)
			complaint_type
			(
				type = picklist
				displayname = "Complaint Type"
				values = {"Plumbing","Cleanliness","Electrical","Other"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			description
			(
    			type = textarea
				displayname = "Description"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			date_filed
			(
    			type = date
				displayname = "Date Filed"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			status
			(
				type = picklist
				displayname = "Status"
				values = {"In Progress","Resolved","Open"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			assigned_staff
			(
    			type = text
				displayname = "Assigned Staff"
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form fees
		{
			displayname = "Fees"
			success message = "Feis Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			student
			(
				type = list	
				displayname = "Student"
				values  = students.ID
    			displayformat = [student_id]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
				height = 13px
	 			row = 1
	 			column = 1   
				width = medium
			)
			total_fee_amount
			(
				displayname = "Total Fee Amount"
				type = USD
	 			row = 1
	 			column = 1   
				width = medium
			)
			amount_paid
			(
				displayname = "Amount Paid"
				type = USD
	 			row = 1
	 			column = 1   
				width = medium
			)
			balance
			(
				displayname = "Balance"
				type = USD
	 			row = 1
	 			column = 1   
				width = medium
			)
			payment_status
			(
				type = picklist
				displayname = "Payment Status"
				values = {"Partial","Paid","Pending"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			payment_date
			(
    			type = date
				displayname = "Payment Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
			blueprint components
			{
				stages = {"Fee Record Created","Payment Pending","Fee Waiver Requested","Payment Received","Payment Delayed","Fee Waiver Approved","Payment Processed","Payment Rejected","Balance Updated","Partial Payment Received","Fee Record Closed","Payment Adjustment Required","Adjustment Processed","Adjustment Rejected","Late Fee Applied","Fee Record Reopened"}
			}
		}
		form rooms
