				displayname = "Course / Department"
				values = {"Chemistry","Psychology","Computer Science","Biology","Mathematics","Mechanical Engineering","Business Administration","Physics","Electrical Engineering"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			year_of_study
			(
				type = picklist
				displayname = "Year of Study"
				values = {"First Year","Fourth Year","Second Year","Third Year"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			guardian_name
			(
    			type = name
				displayname = "Guardian Name"
     			prefix
     			(
	     			 type = prefix
	     			 displayname ="Prefix"
	     			 visibility = false
	     			 value = {"Mr.","Mrs.","Ms."}
     			) 
     			first_name
     			(
	     			 type = first_name
	     			 displayname ="First Name"
     			) 
     			last_name
     			(
	     			 type = last_name
	     			 displayname ="Last Name"
