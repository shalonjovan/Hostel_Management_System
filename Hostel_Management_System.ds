	reports
	{
		list complaints_Report
		{
			displayName = "All Complaints"
			show all rows from complaints    
			(
				student as "Student"
				room as "Room"
				complaint_type as "Complaint Type"
				description as "Description"
				date_filed as "Date Filed"
				status as "Status"
				assigned_staff as "Assigned Staff"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (complaint_type == "Electrical")
				fields = [complaint_type]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (complaint_type == "Other")
				fields = [complaint_type]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (complaint_type == "Plumbing")
				fields = [complaint_type]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		kanban complaints_by_complaint_type
		{
			displayName = "Complaint Types"
			show all rows from complaints    
			(
				student as "Student"
				room as "Room"
				complaint_type as "Complaint Type"
				description as "Description"
				date_filed as "Date Filed"
				status as "Status"
				assigned_staff as "Assigned Staff"
			)
			options
			(
	 			display field = complaint_type
	 		)
		}
		list students_Report
		{
			displayName = "All Students"
			show all rows from students    
			(
				student_id as "Student ID"
				full_name  as "Full Name"
	 			(
	      			displayformat = [first_name+""+prefix+""+last_name+""+suffix]
	 			)
				gender as "Gender"
				date_of_birth as "Date of Birth"
				phone_number as "Phone Number"
				email as "Email"
				course_department as "Course / Department"
				year_of_study as "Year of Study"
				guardian_name  as "Guardian Name"
	 			(
	      			displayformat = [first_name+""+prefix+""+last_name+""+suffix]
	 			)
				guardian_phone as "Guardian Phone"
				address  as "Address"
	 			(
	      			displayformat = [address_line_1+""+address_line_2+""+district_city+""+state_province+""+postal_Code+""+country]
	      			enable = Link_to_Map,Show_As_Text
	 			)
				room_assigned as "Room Assigned"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (gender == "Female")
				fields = [gender]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (gender == "Male")
				fields = [gender]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (gender == "Other")
				fields = [gender]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		kanban students_by_course_department
		{
			displayName = "Students Board"
			show all rows from students    
			(
				student_id as "Student ID"
				full_name  as "Full Name"
	 			(
	      			displayformat = [first_name+""+prefix+""+last_name+""+suffix]
	 			)
				gender as "Gender"
				date_of_birth as "Date of Birth"
				phone_number as "Phone Number"
				email as "Email"
				course_department as "Course / Department"
				year_of_study as "Year of Study"
				guardian_name  as "Guardian Name"
	 			(
	      			displayformat = [first_name+""+prefix+""+last_name+""+suffix]
	 			)
				guardian_phone as "Guardian Phone"
				address  as "Address"
	 			(
	      			displayformat = [address_line_1+""+address_line_2+""+district_city+""+state_province+""+postal_Code+""+country]
	      			enable = Link_to_Map,Show_As_Text
	 			)
				room_assigned as "Room Assigned"
			)
			options
			(
	 			display field = course_department
	 		)
		}
		list fees_Report
		{
			displayName = "All Fees"
			show all rows from fees    
			(
				student as "Student"
				total_fee_amount as "Total Fee Amount"
				(
					display = total,average,min,max	
				)
				amount_paid as "Amount Paid"
				(
					display = total,average,min,max	
				)
				balance as "Balance"
				(
					display = total,average,min,max	
				)
				payment_status as "Payment Status"
				payment_date as "Payment Date"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (payment_status == "Paid")
				fields = [payment_status]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (payment_status == "Partial")
				fields = [payment_status]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (payment_status == "Pending")
				fields = [payment_status]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		kanban fees_by_payment_status
		{
			displayName = "Payment Statuses"
			show all rows from fees    
			(
				student as "Student"
				total_fee_amount as "Total Fee Amount"
				(
					display = total,average,min,max	
				)
				amount_paid as "Amount Paid"
				(
					display = total,average,min,max	
				)
				balance as "Balance"
				(
					display = total,average,min,max	
				)
				payment_status as "Payment Status"
				payment_date as "Payment Date"
			)
			options
			(
	 			display field = payment_status
	 		)
		}
		list rooms_Report
		{
			displayName = "All Rooms"
			show all rows from rooms    
			(
				room_id as "Room ID"
				block_name as "Block Name"
				floor_number as "Floor Number"
				room_number as "Room Number"
				room_type as "Room Type"
				capacity as "Capacity"
				current_occupancy as "Current Occupancy"
				availability_status as "Availability Status"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (room_type == "Single")
				fields = [room_type]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (room_type == "Triple")
				fields = [room_type]
				format = "color:#000000;background-color:#1bbc9b;"
				}
			)
		}
		kanban rooms_by_room_type
		{
			displayName = "Room Types"
			show all rows from rooms    
			(
				room_id as "Room ID"
				block_name as "Block Name"
				floor_number as "Floor Number"
				room_number as "Room Number"
				room_type as "Room Type"
				capacity as "Capacity"
				current_occupancy as "Current Occupancy"
				availability_status as "Availability Status"
			)
			options
			(
	 			display field = room_type
	 		)
		}
